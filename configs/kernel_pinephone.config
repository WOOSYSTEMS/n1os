# N1OS Kernel Configuration for PinePhone (Allwinner A64)
# Based on mainline Linux defconfig with PinePhone-specific options
#
# This is a fragment file — applied on top of defconfig via merge_config.sh

# === Platform: Allwinner A64 (sun50i) ONLY ===
CONFIG_ARCH_SUNXI=y
# Disable all other platforms to speed up build and avoid missing file errors
CONFIG_ARCH_ACTIONS=n
CONFIG_ARCH_AIROHA=n
CONFIG_ARCH_APPLE=n
CONFIG_ARCH_BCM=n
CONFIG_ARCH_BCM2835=n
CONFIG_ARCH_BERLIN=n
CONFIG_ARCH_BRCMSTB=n
CONFIG_ARCH_EXYNOS=n
CONFIG_ARCH_HISI=n
CONFIG_ARCH_K3=n
CONFIG_ARCH_LAYERSCAPE=n
CONFIG_ARCH_LG1K=n
CONFIG_ARCH_MEDIATEK=n
CONFIG_ARCH_MESON=n
CONFIG_ARCH_MVEBU=n
CONFIG_ARCH_MXC=n
CONFIG_ARCH_NPCM=n
CONFIG_ARCH_NXP=n
CONFIG_ARCH_QCOM=n
CONFIG_ARCH_REALTEK=n
CONFIG_ARCH_RENESAS=n
CONFIG_ARCH_ROCKCHIP=n
CONFIG_ARCH_S32=n
CONFIG_ARCH_SEATTLE=n
CONFIG_ARCH_SPARX5=n
CONFIG_ARCH_SPRD=n
CONFIG_ARCH_STM32=n
CONFIG_ARCH_SYNQUACER=n
CONFIG_ARCH_TEGRA=n
CONFIG_ARCH_THUNDER=n
CONFIG_ARCH_THUNDER2=n
CONFIG_ARCH_UNIPHIER=n
CONFIG_ARCH_VEXPRESS=n
CONFIG_ARCH_VISCONTI=n
CONFIG_ARCH_XGENE=n
CONFIG_ARCH_ZYNQMP=n

# === Device Tree ===
CONFIG_ARM64_VA_BITS_48=y

# === Display / GPU ===
# Lima (open-source Mali-400/450 driver)
CONFIG_DRM=y
CONFIG_DRM_LIMA=y
CONFIG_DRM_SUN4I=y
CONFIG_DRM_SUN8I_MIXER=y
CONFIG_DRM_SUN8I_DW_HDMI=n
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_SITRONIX_ST7703=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y

# === Touch / Input ===
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_GOODIX=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_AXP20X_PEK=y
CONFIG_INPUT_GPIO_VIBRA=y

# === Audio ===
CONFIG_SND_SOC=y
CONFIG_SND_SUN4I_CODEC=y
CONFIG_SND_SUN8I_CODEC_ANALOG=y
CONFIG_SND_SUN50I_CODEC_ANALOG=y
CONFIG_SND_SUN4I_I2S=y

# === Modem (Quectel EG25-G) ===
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_OPTION=y
CONFIG_USB_NET_QMI_WWAN=y
CONFIG_USB_NET_CDC_MBIM=y

# === WiFi (RTL8723CS) ===
CONFIG_CFG80211=y
CONFIG_RTL8723CS=m
CONFIG_STAGING=y

# === Bluetooth ===
CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_3WIRE=y
CONFIG_BT_RTL=y

# === Power Management ===
CONFIG_AXP20X_POWER=y
CONFIG_BATTERY_AXP20X=y
CONFIG_AXP20X_ADC=y
CONFIG_CHARGER_AXP20X=y
CONFIG_REGULATOR_AXP20X=y
CONFIG_MFD_AXP20X_RSB=y
CONFIG_MFD_AXP20X_I2C=y

# === Sensors ===
CONFIG_IIO=y
CONFIG_INV_MPU6050_I2C=y
CONFIG_STK3310=y
CONFIG_SENSORS_LM90=y

# === Camera ===
CONFIG_VIDEO_V4L2=y
CONFIG_VIDEO_OV5640=y
CONFIG_VIDEO_SUN6I_CSI=y

# === LEDs ===
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_SGM3140=y

# === GPS ===
CONFIG_GNSS=y
CONFIG_GNSS_SERIAL=y

# === USB / OTG ===
CONFIG_USB=y
CONFIG_USB_MUSB_HDRC=y
CONFIG_USB_MUSB_SUNXI=y
CONFIG_USB_GADGET=y
CONFIG_USB_ETH=m

# === Storage ===
CONFIG_MMC=y
CONFIG_MMC_SUNXI=y
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y

# === Performance: schedutil governor ===
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPUFREQ_DT=y
CONFIG_SUN50I_CPUFREQ_NVMEM=y

# === zram swap ===
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_ZSTD=y

# === Networking ===
CONFIG_NET=y
CONFIG_INET=y
CONFIG_WIRELESS=y
CONFIG_RFKILL=y

# === Wayland/DRM requirements ===
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

# === Trim for performance ===
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_KERNEL=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n
CONFIG_PROFILING=n
CONFIG_SLUB_DEBUG=n

# === Compression ===
CONFIG_KERNEL_LZ4=y
CONFIG_RD_LZ4=y

# === Cgroups (needed for containers/process management) ===
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y

# === tmpfs ===
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# === inotify ===
CONFIG_INOTIFY_USER=y

# === devtmpfs (needed for udev-free boot) ===
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
